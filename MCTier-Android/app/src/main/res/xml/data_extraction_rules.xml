<?xml version="1.0" encoding="utf-8"?>
<!-- 合规：禁止云备份与设备迁移导出本应用数据，避免个人信息随系统备份外泄 -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="." />
    </device-transfer>
</data-extraction-rules>
